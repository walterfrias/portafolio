  </div>

</div>

<style>
@keyframes amber-glow-pulse {
  0%, 100% {
    text-shadow: none;
  }
  50% {
    text-shadow: 0 0 8px rgba(251, 191, 36, 0.45), 0 0 20px rgba(251, 191, 36, 0.15);
  }
}

.nav-glow {
  animation: amber-glow-pulse 2.8s ease-in-out infinite;
}

a:hover .nav-glow {
  animation-play-state: paused;
  text-shadow: none;
}
</style>
