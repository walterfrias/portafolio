      <a href="#about" class="group flex items-center gap-4 text-slate-500 hover:text-amber-300 transition-colors duration-200">
        <span class="h-px w-8 bg-slate-700 group-hover:w-16 group-hover:bg-amber-300 transition-all duration-300"></span>
        <span class="text-xs font-semibold tracking-widest uppercase">About</span>
      </a>
      <a href="#projects" class="group flex items-center gap-4 text-slate-500 hover:text-amber-300 transition-colors duration-200">
