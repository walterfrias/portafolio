---
---

<div class="flex flex-col h-full">

  <div class="flex-1 flex flex-col justify-center">
    <p class="text-slate-500 text-sm font-mono mb-3">Hello, I'm</p>

    <h1 class="text-4xl font-bold text-white mb-2 leading-tight">
      Walter Frias
    </h1>

    <h2 class="text-base text-slate-400 font-medium mb-6 leading-snug">
      Full Stack Developer<br />
      Python · TypeScript
    </h2>

    <p class="text-slate-500 text-sm leading-relaxed max-w-xs mb-16">
      Building web2 products and web3 protocols. I bring a visual arts
      background to every interface I craft.
    </p>

    <nav class="flex flex-col gap-5">
      <a href="#about" class="group flex items-center gap-4 text-slate-500 hover:text-amber-300 transition-colors duration-200">
        <span class="h-px w-8 bg-slate-700 group-hover:w-16 group-hover:bg-amber-300 transition-all duration-300"></span>
        <span class="text-xs font-semibold tracking-widest uppercase nav-glow" style="animation-delay: 0s">About</span>
      </a>
      <a href="#projects" class="group flex items-center gap-4 text-slate-500 hover:text-amber-300 transition-colors duration-200">
        <span class="h-px w-8 bg-slate-700 group-hover:w-16 group-hover:bg-amber-300 transition-all duration-300"></span>
        <span class="text-xs font-semibold tracking-widest uppercase nav-glow" style="animation-delay: 0.7s">Projects</span>
      </a>
      <a href="#skills" class="group flex items-center gap-4 text-slate-500 hover:text-amber-300 transition-colors duration-200">
        <span class="h-px w-8 bg-slate-700 group-hover:w-16 group-hover:bg-amber-300 transition-all duration-300"></span>
        <span class="text-xs font-semibold tracking-widest uppercase nav-glow" style="animation-delay: 1.4s">Skills</span>
      </a>
      <a href="#contact" class="group flex items-center gap-4 text-slate-500 hover:text-amber-300 transition-colors duration-200">
        <span class="h-px w-8 bg-slate-700 group-hover:w-16 group-hover:bg-amber-300 transition-all duration-300"></span>
        <span class="text-xs font-semibold tracking-widest uppercase nav-glow" style="animation-delay: 2.1s">Contact</span>
      </a>
    </nav>
  </div>

  <div class="flex items-center gap-5 mt-8">
    <a href="/Walter_Frias_CV.pdf" download
       class="flex items-center gap-2 text-xs font-semibold tracking-widest uppercase text-slate-500 hover:text-amber-300 transition-colors duration-200"
       aria-label="Download CV">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
        <polyline points="7 10 12 15 17 10"/>
        <line x1="12" y1="15" x2="12" y2="3"/>
      </svg>
      Resume
    </a>
    <span class="text-slate-700">|</span>
    <a href="https://github.com/walterfrias" target="_blank" rel="noopener noreferrer"
       aria-label="GitHub"
       class="text-slate-500 hover:text-amber-300 transition-colors duration-200">
