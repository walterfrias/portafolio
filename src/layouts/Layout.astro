---
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Walter Frias — Full Stack Developer",
  description = "Full stack web2 and web3 developer. Building modern products with React, Next.js, Django, and Solidity.",
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-slate-950 text-white antialiased">
    <div class="lg:flex min-h-screen max-w-screen-xl mx-auto">

      <aside class="lg:w-5/12 lg:sticky lg:top-0 lg:h-screen lg:overflow-y-auto px-8 pt-16 pb-8 lg:px-16 lg:py-24">
        <slot name="sidebar" />
      </aside>

      <main class="lg:w-7/12 px-8 lg:px-16 py-16 lg:py-24">
        <slot />
        <Footer />
      </main>

    </div>
  </body>
</html>
